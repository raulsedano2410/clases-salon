# Telegram Bot Token - obtener de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui

# Google Gemini API Key - obtener gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# URL publica donde estara tu app (para el webhook de Telegram)
APP_URL=https://tu-app.onrender.com

# Clave secreta para el webhook
WEBHOOK_SECRET=cambia_esto_por_algo_seguro
